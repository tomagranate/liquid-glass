{
  "name": "@tomagranate/liquid-glass",
  "version": "0.0.1",
  "description": "A framework-independent liquid-glass (Apple-style refraction) effect for the web, built on the SVG feDisplacementMap filter, with React bindings and a WebGL texture backend for canvas/video.",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite examples/demo",
    "build": "tsup",
    "build:demo": "vite build examples/demo",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "npm run test:unit && npm run test:browser",
    "test:unit": "vitest run --exclude 'src/**/*.browser.test.ts' --exclude 'src/**/*.browser.test.tsx'",
    "pretest:browser": "playwright install chromium",
    "test:browser": "vitest run --browser.enabled src/core/liquid-glass.browser.test.ts",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "liquid-glass",
    "glass",
    "refraction",
    "webgl",
    "react",
    "displacement-map",
    "ui",
    "effect",
    "apple"
  ],
  "author": "Tom <tom@sunburst.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomagranate/liquid-glass.git"
  },
  "homepage": "https://github.com/tomagranate/liquid-glass#readme",
  "bugs": {
    "url": "https://github.com/tomagranate/liquid-glass/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/browser": "^3.2.6",
    "jsdom": "^25.0.1",
    "playwright": "^1.61.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
