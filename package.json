{
  "name": "@tomagranate/liquid-glass",
  "version": "0.1.0",
  "description": "A framework-independent liquid-glass (Apple-style refraction) effect for the web, with React components and a WebGL renderer.",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite examples/demo",
    "build": "tsup",
    "build:demo": "vite build examples/demo",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "liquid-glass",
    "glass",
    "refraction",
    "webgl",
    "react",
    "displacement-map",
    "ui",
    "effect",
    "apple"
  ],
  "author": "Tom <tom@sunburst.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomagranate/liquid-glass.git"
  },
  "homepage": "https://github.com/tomagranate/liquid-glass#readme",
  "bugs": {
    "url": "https://github.com/tomagranate/liquid-glass/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "html-to-image": "^1.11.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
